cd /raid/home/hming/FusionRAG-pca-analysis
tmux new -s cross_dataset_supervisor \
  'bash MOTIVATION_EXPERIMENTS/cross_dataset_offline_generalization/run_cross_dataset_supervisor.sh'
```

